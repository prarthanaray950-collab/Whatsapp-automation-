# ── OpenRouter (AI) ───────────────────────────────────────────────────────────
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use — free options: meta-llama/llama-3.3-8b-instruct:free
# Paid options: anthropic/claude-3-haiku, openai/gpt-4o-mini, google/gemini-flash-1.5
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/satvikmeals

# ── Website API ───────────────────────────────────────────────────────────────
# URL of your SatvikMeals backend — used to fetch live menu & plans and create users
WEBSITE_API_URL=https://satvikmeals.com

# Optional shared secret between bot and website (add this check to your /api/auth/dev-login route)
BOT_SECRET=your_random_secret_here

# ── Admin WhatsApp Notifications ──────────────────────────────────────────────
# Your WhatsApp number with country code (no + or spaces)
ADMIN_WHATSAPP=919031447621

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
